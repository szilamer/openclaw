# Előre buildelt - node_modules és dist lokálisan készül, nem fut npm a VPS-en
FROM node:22-alpine

WORKDIR /app

# Csak másolás, nincs npm install
COPY package*.json ./
COPY prisma ./prisma/
COPY dist ./dist/
COPY node_modules ./node_modules/

RUN npx prisma generate

EXPOSE 3000

CMD ["sh", "-c", "npx prisma migrate deploy 2>/dev/null || true && node dist/src/main.js"]
