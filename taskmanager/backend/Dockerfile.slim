# Slim build - előre buildelt fájlok másolása (helyfoglalás csökkentése)
FROM node:22-alpine

WORKDIR /app

# Csak a szükséges fájlok
COPY package*.json ./
COPY prisma ./prisma/
COPY dist ./dist/

# Csak production deps
RUN npm install --omit=dev && npx prisma generate

EXPOSE 3000

CMD ["sh", "-c", "npx prisma migrate deploy 2>/dev/null || true && node dist/src/main.js"]
