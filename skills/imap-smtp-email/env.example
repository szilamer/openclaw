# Másold `.env` néven ugyanebbe a mappába (ne commitold). Mac Mini: ~/.openclaw/workspace/skills/imap-smtp-email/.env

IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=user@example.com
IMAP_PASS=
IMAP_TLS=true
IMAP_REJECT_UNAUTHORIZED=false
IMAP_MAILBOX=INBOX

# Mission Control API (intake + triage register)
TASKMANAGER_BASE_URL=https://your-mission-control.example/api
TASKMANAGER_AGENT_TOKEN=

# Ollama (Stage 1 triage classification)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
